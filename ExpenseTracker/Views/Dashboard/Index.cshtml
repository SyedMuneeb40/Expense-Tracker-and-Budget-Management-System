@{
    ViewData["Title"] = "Dashboard";
}

<div class="row mb-4">
    <div class="col-md-4">
        <div class="card text-white bg-primary mb-3" style="height: 150px;">
            <div class="card-body d-flex flex-column justify-content-center align-items-center">
                <h5 class="card-title">Total Balance</h5>
                <h2 class="card-text">@ViewBag.Balance</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-success mb-3" style="height: 150px;">
            <div class="card-body d-flex flex-column justify-content-center align-items-center">
                <h5 class="card-title">Income</h5>
                <h2 class="card-text">@ViewBag.TotalIncome</h2>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card text-white bg-danger mb-3" style="height: 150px;">
            <div class="card-body d-flex flex-column justify-content-center align-items-center">
                <h5 class="card-title">Expense</h5>
                <h2 class="card-text">@ViewBag.TotalExpense</h2>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <h3>Recent Transactions</h3>
        <table class="table table-hover">
            <thead class="table-dark">
                <tr>
                    <th>Category</th>
                    <th>Date</th>
                    <th>Amount</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in ViewBag.RecentTransactions)
                {
                    <tr>
                        <td>@item.Category.Icon @item.Category.Title</td>
                        <td>@item.Date.ToString("MMM-dd-yyyy")</td>
                        <td class="@(item.Category.Type == "Income" ? "text-success" : "text-danger")">
                            @item.Category.TypeStr @item.Amount
                        </td>
                        <td>
                            <form asp-action="Delete" asp-controller="Transaction" asp-route-id="@item.TransactionId">
                                <button type="submit" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this?')"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="col-md-6 d-flex align-items-center justify-content-center">
        <a asp-controller="Transaction" asp-action="AddOrEdit" class="btn btn-lg btn-warning">
            <i class="bi bi-plus-circle"></i> Add New Transaction
        </a>
    </div>
</div>